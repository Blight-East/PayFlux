#!/usr/bin/env bash
#
# pre-push: block pushes that would fail the Netlify build.
#
# Activated by: git config core.hooksPath .githooks
#
# Rationale: Netlify failures are expensive feedback — the build runs
# minutes after a push and blocks deploys. Running the same build
# locally before push catches the most common causes (TypeScript,
# missing imports, route conflicts) in ~30s.
#
# Skip when the outgoing range doesn't touch apps/dashboard — no point
# rebuilding the dashboard for a Go-only change. Bypass with
# PAYFLUX_SKIP_PREPUSH=1 git push when you need to ship a branch that
# you know is mid-refactor.

set -euo pipefail

if [[ "${PAYFLUX_SKIP_PREPUSH:-0}" == "1" ]]; then
    echo "pre-push: skipped (PAYFLUX_SKIP_PREPUSH=1)"
    exit 0
fi

# Read the push refs from stdin (git pre-push protocol).
# Format per line: <local ref> <local sha> <remote ref> <remote sha>
touches_dashboard=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
    # Skip deletions.
    if [[ "$local_sha" =~ ^0+$ ]]; then
        continue
    fi

    # New branch: diff against the remote's default branch.
    if [[ "$remote_sha" =~ ^0+$ ]]; then
        range="origin/main..$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi

    if git diff --name-only "$range" 2>/dev/null | grep -q '^apps/dashboard/'; then
        touches_dashboard=1
        break
    fi
done

if [[ "$touches_dashboard" == "0" ]]; then
    echo "pre-push: no apps/dashboard changes in outgoing commits, skipping build"
    exit 0
fi

echo "pre-push: building apps/dashboard (set PAYFLUX_SKIP_PREPUSH=1 to bypass)…"

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root/apps/dashboard"

if ! npm run build --silent; then
    echo
    echo "pre-push: dashboard build failed — push blocked."
    echo "  Fix the build, or re-run with PAYFLUX_SKIP_PREPUSH=1 if you know what you're doing."
    exit 1
fi

echo "pre-push: build ok"
