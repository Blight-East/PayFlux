#!/usr/bin/env bash
#
# pre-push: block pushes that would fail the Netlify build.
#
# Activated by: git config core.hooksPath .githooks
#
# Rationale: Netlify failures are expensive feedback — the build runs
# minutes after a push and blocks deploys. Running the same build
# locally before push catches the most common causes (TypeScript,
# missing imports, route conflicts) in ~30s.
#
# Skip when the outgoing range doesn't touch apps/dashboard — no point
# rebuilding the dashboard for a Go-only change. Bypass with
# PAYFLUX_SKIP_PREPUSH=1 git push when you need to ship a branch that
# you know is mid-refactor.

set -euo pipefail

if [[ "${PAYFLUX_SKIP_PREPUSH:-0}" == "1" ]]; then
    echo "pre-push: skipped (PAYFLUX_SKIP_PREPUSH=1)"
    exit 0
fi

# Read the push refs from stdin (git pre-push protocol).
# Format per line: <local ref> <local sha> <remote ref> <remote sha>
touches_dashboard=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
    # Skip deletions.
    if [[ "$local_sha" =~ ^0+$ ]]; then
        continue
    fi

    # New branch: diff against the remote's default branch.
    if [[ "$remote_sha" =~ ^0+$ ]]; then
        range="origin/main..$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi

    if git diff --name-only "$range" 2>/dev/null | grep -q '^apps/dashboard/'; then
        touches_dashboard=1
        break
    fi
done

if [[ "$touches_dashboard" == "0" ]]; then
    echo "pre-push: no apps/dashboard changes in outgoing commits, skipping build"
    exit 0
fi

echo "pre-push: building apps/dashboard against HEAD (set PAYFLUX_SKIP_PREPUSH=1 to bypass)…"

repo_root=$(git rev-parse --show-toplevel)

# Build against exactly what's being pushed — HEAD with no untracked or
# modified files in the way. Netlify sees only what's committed; the gate
# should match. We stash any working-tree differences and pop them back at
# the end (including on failure), so the developer's WIP is preserved.
stash_label="payflux-pre-push-$(date +%s)"
stashed=0
if ! git -C "$repo_root" diff --quiet HEAD || [[ -n "$(git -C "$repo_root" ls-files --others --exclude-standard)" ]]; then
    if git -C "$repo_root" stash push --include-untracked --quiet -m "$stash_label" 2>/dev/null; then
        stashed=1
    else
        echo "pre-push: failed to stash working tree — push blocked."
        echo "  Commit or stash your changes manually, then retry."
        exit 1
    fi
fi

restore_stash() {
    if [[ "$stashed" == "1" ]]; then
        # The stash we created should be on top; pop quietly.
        git -C "$repo_root" stash pop --quiet >/dev/null 2>&1 || \
            echo "pre-push: WARNING — failed to auto-pop stash '$stash_label'; run \`git stash list\` and pop manually."
    fi
}
trap restore_stash EXIT

cd "$repo_root/apps/dashboard"

# Use `netlify build --offline` when the CLI is available — it runs the same
# plugin pipeline Netlify CI runs (including @netlify/plugin-nextjs), which
# catches a class of failures that `npm run build` alone misses (e.g. missing
# middleware artifacts the plugin expects). Falls back to npm run build if
# the CLI is missing.
if command -v netlify >/dev/null 2>&1; then
    if ! netlify build --offline >/dev/null 2>&1; then
        echo
        echo "pre-push: \`netlify build --offline\` failed — push blocked."
        echo "  Re-run \`netlify build --offline\` from apps/dashboard to see the error."
        echo "  Or bypass with PAYFLUX_SKIP_PREPUSH=1 if you know what you're doing."
        exit 1
    fi
else
    if ! npm run build --silent; then
        echo
        echo "pre-push: dashboard build failed — push blocked."
        echo "  Fix the build, or re-run with PAYFLUX_SKIP_PREPUSH=1 if you know what you're doing."
        exit 1
    fi
fi

echo "pre-push: build ok"
