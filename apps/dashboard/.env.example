# ──────────────────────────────────────────────────────────────────────────────
# PayFlux Dashboard — Environment Variables
# Copy to .env.local and fill in values before running.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Authentication (Clerk) ──────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE
CLERK_SECRET_KEY=sk_test_REPLACE

# ─── OAuth State Signing ─────────────────────────────────────────────────────
OAUTH_STATE_SECRET=REPLACE_WITH_RANDOM_SECRET

# ─── Stripe ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_CLIENT_ID=ca_REPLACE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE
STRIPE_SECRET_KEY=sk_test_REPLACE
STRIPE_PRICE_ID=price_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE
STRIPE_BILLING_WEBHOOK_SECRET=whsec_REPLACE
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=bpc_REPLACE
STRIPE_PRICE_ID_PRO=price_REPLACE
# STRIPE_PRICE_ID_ENTERPRISE=price_REPLACE

# ─── PayFlux Backend (Go payment-node, deployed on Fly) ──────────────────────
# IMPORTANT: api.payflux.dev resolves to Agent Flux (Python), NOT the Go core.
# All PayFlux Go API calls must go to payflux-core.fly.dev directly.
PAYFLUX_API_URL=https://payflux-core.fly.dev
PAYFLUX_API_KEY=REPLACE
# PAYFLUX_AUTH_TOKEN=REPLACE (alternative to PAYFLUX_API_KEY)

# PAYFLUX_INGEST_URL forwards normalized Stripe Connect events
# (payment_intent.payment_failed, payment_intent.succeeded) to the Go core.
#
# Phase 2 wiring (resolveMerchantContextFromEvent + UUIDv5 event ids + lazy
# country bucket cache on processor_connections.connection_metadata) is live —
# the normalizer drops events it can't attribute to a workspace, so enabling
# this no longer pollutes Go with merchant_id='unknown' rows.
#
# Cutover steps:
#   1. Set this var to https://payflux-core.fly.dev/v1/events/payment_exhaust
#      in Netlify (all 4 contexts), confirm PAYFLUX_API_KEY is also set.
#   2. Trigger a Stripe test event from a connected sandbox account; watch for
#      payflux_forward_non_2xx in dashboard logs and ingestDuplicate /
#      eventsByProcessor metrics on the Go side.
#   3. If 1+ event lands cleanly, leave enabled. If you see country=null in
#      cache for non-test merchants, the lazy lookup logged
#      stripe_account_country_lookup_failed — investigate that account.
# PAYFLUX_INGEST_URL=https://payflux-core.fly.dev/v1/events/payment_exhaust

# ─── Upstream / Core API (fallback) ─────────────────────────────────────────
CORE_BASE_URL=https://payflux-core.fly.dev
CORE_AUTH_TOKEN=REPLACE
PAYFLUX_UPSTREAM_URL=https://payflux-core.fly.dev

# ─── Database (omit for SQLite local dev, set for Postgres in production) ──
# DATABASE_URL=postgresql://user:pass@host:5432/payflux

# ─── Redis (Upstash REST API) ───────────────────────────────────────────────
RISK_REDIS_URL=https://REPLACE.upstash.io
RISK_REDIS_TOKEN=REPLACE

# ─── Evidence Export ─────────────────────────────────────────────────────────
EVIDENCE_SECRET=REPLACE_WITH_RANDOM_SECRET

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_TOKEN=REPLACE

# ─── Founder Bypass ───────────────────────────────────────────────────────────
# Immutable Clerk user IDs — checked first, no API call needed.
# ADMIN_USER_IDS=user_abc123,user_def456
# Email fallback — checked second via Clerk API lookup.
# ADMIN_EMAILS=founder@payflux.dev,ops@payflux.dev

# ─── Application URLs ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://payflux.dev

# ─── AI/ML (optional) ───────────────────────────────────────────────────────
# GEMINI_API_KEY=REPLACE

# ─── Monitoring (optional) ──────────────────────────────────────────────────
# PROMETHEUS_URL=http://localhost:19090

# ─── Feature Flags (optional, all default to disabled) ──────────────────────
# DASHBOARD_V2_ENABLED=false
# DASHBOARD_ALLOW_PILOT_ENDPOINTS=false
# DASHBOARD_PERSIST_CONFIG=false
# DASHBOARD_WEBHOOK_TEST_BYPASS=false
# EVIDENCE_SEED_ENABLED=false

# ─── Environment / Tier ─────────────────────────────────────────────────────
# PAYFLUX_ENV=development
# PAYFLUX_TIER=PILOT

# ─── Build-time (set by CI/build, not needed locally) ──────────────────────
# NODE_ENV=production
# CANONICAL_SITE_URL=https://payflux.dev
# GIT_SHA=auto
# BUILD_TIME=auto
# PAYFLUX_GIT_SHA=auto
# PAYFLUX_BUILD_TIME=auto
# COMMIT_REF=auto

# ─── Deployment Platform (Netlify) ──────────────────────────────────────────
# DEPLOY_URL=https://branch--name.netlify.app
# DEPLOY_PRIME_URL=https://main--name.netlify.app
# URL=https://payflux.dev
