{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Tier Entitlements Configuration Schema",
    "description": "Schema for tier-based entitlements configuration",
    "type": "object",
    "properties": {
        "entitlements": {
            "type": "object",
            "patternProperties": {
                "^(baseline|proof|shield|fortress)$": {
                    "type": "object",
                    "properties": {
                        "retention_days": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 3650,
                            "description": "Data retention period in days"
                        },
                        "alert_routing_enabled": {
                            "type": "boolean",
                            "description": "Whether alert routing is enabled for this tier"
                        },
                        "sla_response_time_ms": {
                            "type": "integer",
                            "minimum": 100,
                            "maximum": 30000,
                            "description": "Target SLA response time in milliseconds"
                        },
                        "max_concurrent_requests": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 10000,
                            "description": "Maximum concurrent requests allowed"
                        },
                        "export_formats": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "json",
                                    "csv",
                                    "parquet",
                                    "avro"
                                ]
                            },
                            "minItems": 1,
                            "uniqueItems": true,
                            "description": "Allowed export formats"
                        }
                    },
                    "required": [
                        "retention_days",
                        "alert_routing_enabled",
                        "sla_response_time_ms",
                        "max_concurrent_requests",
                        "export_formats"
                    ],
                    "additionalProperties": false
                }
            },
            "additionalProperties": false,
            "minProperties": 4,
            "description": "Entitlements per tier"
        }
    },
    "required": [
        "entitlements"
    ],
    "additionalProperties": false
}