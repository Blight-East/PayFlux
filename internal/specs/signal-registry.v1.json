    "scoring_systems": [
        {
            "file": "risk_score.go",
            "function": "calculateWeightedScore",
            "inputs": [
                "c.FailRate",
                "c.RetryPressure",
                "c.TimeoutMix",
                "c.TrafficSpike",
                "c.AuthFailMix",
                "c.GeoEntropy"
            ],
            "formula_raw": "score := (0.25 * c.FailRate) + (0.20 * clamp(c.RetryPressure)) + (0.15 * clamp(c.TimeoutMix)) + (0.15 * clamp(c.TrafficSpike)) + (0.10 * clamp(c.AuthFailMix)) + (0.15 * clamp(c.GeoEntropy)); return clamp(score)",
            "caps_or_clamps": "clamp(v) returns 0 if v<0, 1 if v>1, else v; final score clamped to [0,1]",
            "ordering_rules": "N/A - weighted sum"
        },
        {
            "file": "risk_score.go",
            "function": "mapScoreToBand",
            "inputs": [
                "score",
                "s.elevated",
                "s.high",
                "s.critical"
            ],
            "formula_raw": "if score >= s.critical { return \"critical\" } else if score >= s.high { return \"high\" } else if score >= s.elevated { return \"elevated\" }; return \"low\"",
            "caps_or_clamps": "thresholds default [0.3, 0.6, 0.8]; configurable via PAYFLUX_RISK_SCORE_THRESHOLDS",
            "ordering_rules": "descending threshold check (critical > high > elevated > low)"
        },
        {
            "file": "risk_score.go",
            "function": "calculateTrajectory",
            "inputs": [
                "hist",
                "currentIdx"
            ],
            "formula_raw": "curFR = currentBucket.Failures / currentBucket.TotalEvents; baseFR = otherFailures / otherEvents; multiplier = curFR / baseFR if baseFR > 0.01 else (10.0 if curFR > 0.1 else 1.0); multiplier = round(multiplier*10)/10; direction = 'accelerating' if multiplier >= 2.0 else ('decelerating' if multiplier <= 0.5 && baseFR > 0.05 else 'stable')",
            "caps_or_clamps": "multiplier rounded to 1 decimal place; minimum baseFR threshold 0.01",
            "ordering_rules": "N/A"
        },
        {
            "file": "risk_score.go",
            "function": "computeComponentScores",
            "inputs": [
                "stats",
                "currentBucket"
            ],
            "formula_raw": "FailRate = Failures/TotalEvents; RetryPressure = (RetrySum/TotalEvents)/3.0; TimeoutMix = Timeouts/Failures; AuthFailMix = AuthFails/Failures; TrafficSpike = (currentRate / avgOtherRate) / 2.0; GeoEntropy = GeoCount / 10.0",
            "caps_or_clamps": "avgOtherRate minimum 1.0; all components implicitly clamped in weighted score",
            "ordering_rules": "N/A"
        }
    ],
